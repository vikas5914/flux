    "@tanstack/react-query": "^5.90.21",
    "convex": "^1.32.0",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-grab": "^0.1.21",
    "react-router-dom": "^7.6.0",
    "wrangler": "^4.69.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^24.6.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
