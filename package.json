    "typescript": "~5.9.3",
    "typescript-eslint": "^8.45.0",
    "vite": "^7.1.9",
    "vite-plugin-pwa": "^1.1.0",
    "workbox-core": "^7.3.0",
    "workbox-window": "^7.4.0"
  },
  "resolutions": {
    "sharp": "^0.33.5",
